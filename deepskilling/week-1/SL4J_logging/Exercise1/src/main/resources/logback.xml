<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Logback Configuration
        Controls log format, output destination, and minimum log level.
        Place this file in src/main/resources/
    -->

    <!-- Console Appender: prints logs to terminal -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Format: [timestamp] [LEVEL] [ClassName] - message -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%-5level] [%logger{36}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File Appender: saves logs to a file -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/application.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%-5level] [%logger{36}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger: minimum level DEBUG, outputs to both console and file -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>